{
  "name": "@umpire/solid",
  "version": "1.0.0",
  "description": "Solid component adapter for @umpire/core",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.browser.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsdown",
    "prepack": "node ../../scripts/materialize-agent-compat.mjs prepack",
    "postpack": "node ../../scripts/materialize-agent-compat.mjs postpack",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "files": [
    "dist",
    "AGENTS.md",
    ".claude"
  ],
  "dependencies": {
    "@umpire/core": "workspace:^",
    "@umpire/signals": "workspace:^"
  },
  "peerDependencies": {
    "solid-js": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdougbrown/umpire.git",
    "directory": "packages/solid"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "solid-js": "^1.0.0",
    "tsdown": "^0.21.7"
  }
}
