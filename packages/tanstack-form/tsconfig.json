{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@umpire/core": ["../core/src/index.ts"],
      "@umpire/core/*": ["../core/src/*"],
      "@umpire/reads": ["../reads/src/index.ts"],
      "@umpire/react": ["../react/src/index.ts"],
      "@umpire/solid": ["../solid/src/index.ts"],
      "@umpire/signals": ["../signals/src/index.ts"],
      "@umpire/signals/*": ["../signals/src/*"],
      "@umpire/signals/vue": ["../signals/src/adapters/vue.ts"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../core" },
    { "path": "../reads" },
    { "path": "../react" },
    { "path": "../signals" },
    { "path": "../solid" }
  ]
}
