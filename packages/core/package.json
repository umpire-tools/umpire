{
  "name": "@umpire/core",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.browser.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.js"
    },
    "./snapshot": {
      "types": "./dist/snapshot.d.ts",
      "browser": "./dist/snapshot.js",
      "import": "./dist/snapshot.js"
    },
    "./guards": {
      "types": "./dist/guards.d.ts",
      "import": "./dist/guards.js"
    }
  },
  "scripts": {
    "build": "tsc && tsdown",
    "bench": "yarn build && bun ./scripts/benchmark.mjs",
    "bench:profile": "yarn build && MIMALLOC_SHOW_STATS=1 BENCH_HEAP_SNAPSHOT=1 bun --heap-prof-md --heap-prof-dir ./benchmark-profiles ./scripts/benchmark.mjs",
    "prepack": "node ../../scripts/materialize-agent-compat.mjs prepack",
    "postpack": "node ../../scripts/materialize-agent-compat.mjs postpack",
    "test": "bun test",
    "test:mutation": "stryker run",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "files": [
    "dist",
    "AGENTS.md",
    ".claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdougbrown/umpire.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "tsdown": "^0.21.7"
  }
}
