{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@umpire/jsx",
    "noEmit": true,
    "paths": {
      "@umpire/core": ["../../core/src/index.ts"],
      "@umpire/core/*": ["../../core/src/*"],
      "@umpire/dsl": ["../../dsl/src/index.ts"],
      "@umpire/dsl/*": ["../../dsl/src/*"],
      "@umpire/jsx": ["../src/index.ts"],
      "@umpire/jsx/jsx-runtime": ["../src/runtime.ts"],
      "@umpire/jsx/jsx-dev-runtime": ["../src/jsx-dev-runtime.ts"]
    }
  },
  "include": ["."]
}
