{
  "name": "@umpire/signals",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./alien": {
      "types": "./dist/adapters/alien.d.ts",
      "import": "./dist/adapters/alien.js"
    },
    "./preact": {
      "types": "./dist/adapters/preact.d.ts",
      "import": "./dist/adapters/preact.js"
    },
    "./tc39": {
      "types": "./dist/adapters/tc39.d.ts",
      "import": "./dist/adapters/tc39.js"
    },
    "./vue": {
      "types": "./dist/adapters/vue.d.ts",
      "import": "./dist/adapters/vue.js"
    },
    "./solid": {
      "types": "./dist/adapters/solid.d.ts",
      "import": "./dist/adapters/solid.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "node ../../scripts/materialize-agent-compat.mjs prepack",
    "postpack": "node ../../scripts/materialize-agent-compat.mjs postpack",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "files": [
    "dist",
    "AGENTS.md",
    ".claude"
  ],
  "dependencies": {
    "@umpire/core": "workspace:^"
  },
  "peerDependencies": {
    "@preact/signals-core": "^1.0.0",
    "alien-signals": "^3.0.0",
    "signal-polyfill": "^0.2.0",
    "solid-js": "^1.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@preact/signals-core": {
      "optional": true
    },
    "alien-signals": {
      "optional": true
    },
    "signal-polyfill": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdougbrown/umpire.git",
    "directory": "packages/signals"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@preact/signals-core": "^1.12.1",
    "alien-signals": "^3.0.0",
    "signal-polyfill": "^0.2.0",
    "solid-js": "^1.0.0",
    "vue": "^3.0.0"
  }
}
