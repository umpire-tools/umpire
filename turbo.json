{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {},
    "test:mutation": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "//#lint": {
      "dependsOn": ["@umpire/eslint-plugin#build"],
      "inputs": [
        "packages/**/*.{ts,tsx,js}",
        "docs/src/**/*.{ts,js}",
        "eslint.config.js"
      ]
    },
    "//#format:check": {
      "inputs": [
        "packages/**/*.{ts,tsx,js}",
        "scripts/**/*.{ts,mjs}",
        "test/**/*.ts",
        ".prettierrc",
        ".prettierignore",
        "README.md"
      ]
    }
  }
}
