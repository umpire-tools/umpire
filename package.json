{
  "private": true,
  "name": "umpire",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=24",
    "bun": ">=1.2"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "coverage:merge": "bun ./scripts/merge-lcov.mjs",
    "docs": "cd docs && npx astro dev",
    "docs:build": "cd docs && npx astro build",
    "test": "turbo run test",
    "test:coverage": "turbo run test --force -- --coverage --coverage-reporter=lcov --coverage-dir=coverage && bun ./scripts/merge-lcov.mjs",
    "test:smoke": "yarn workspace @umpire/devtools test:smoke",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@happy-dom/global-registrator": "^20.0.10",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
