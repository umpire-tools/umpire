{
  "private": true,
  "name": "umpire",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=22",
    "bun": ">=1.2"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "changeset:version": "changeset version && yarn install",
    "coverage:merge": "bun ./scripts/merge-lcov.mjs",
    "docs": "yarn --cwd docs dev",
    "docs:build": "yarn --cwd docs build",
    "test": "turbo run test",
    "test:coverage": "turbo run test --force -- --coverage --coverage-reporter=lcov --coverage-dir=coverage && bun ./scripts/merge-lcov.mjs",
    "test:coverage:istanbul": "bun ./scripts/test-coverage-istanbul.ts",
    "test:mutation": "turbo run test:mutation",
    "test:smoke": "yarn workspace @umpire/devtools test:smoke",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@happy-dom/global-registrator": "^20.0.10",
    "@types/bun": "^1.3.12",
    "@umpire/eslint-plugin": "workspace:^",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-instrument": "^6.0.3",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "prettier": "^3.8.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2"
  }
}
